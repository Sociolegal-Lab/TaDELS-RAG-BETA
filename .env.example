# Embedding service (Ollama-compatible /api/embed endpoint)
EMBED_URL=http://your-host:port/api/embed
EMBED_MODEL=embeddinggemma:latest

# LLM backend: "claude" or "ollama"
LLM_BACKEND=claude

# Ollama LLM (used when LLM_BACKEND=ollama)
LLM_OLLAMA_URL=http://your-host:port/api/chat
LLM_OLLAMA_MODEL=gemma4:31b

# Claude proxy (used when LLM_BACKEND=claude)
LLM_CLAUDE_URL=http://your-host:port/ask
